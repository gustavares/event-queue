# Database Configuration
# For Docker Compose stack: use the service name (postgres:5432)
# For local dev against docker-hosted Postgres: use localhost:5432
DATABASE_URL=postgres://postgres:postgres@localhost:5432/event_queue

# JWT signing secret — generate a long random string (e.g. `openssl rand -hex 32`)
# Read by backend/src/domain/auth/common/jwt.service.ts
JWT_SECRET=change-me-to-a-long-random-string
